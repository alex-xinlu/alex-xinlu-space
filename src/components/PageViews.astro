---
type Props = {
  class?: string;
  pathname: string;
  showPageViews?: boolean;
  showSiteViews?: boolean;
  size?: "responsive" | "inherit";
  tone?: "muted" | "inherit";
};

const {
  class: className = "",
  pathname,
  showPageViews = true,
  showSiteViews = false,
  size = "responsive",
  tone = "muted",
} = Astro.props;
---

<div
  class:list={[
    "flex items-center gap-x-2",
    size === "responsive" ? "text-sm sm:text-base" : "text-[inherit] leading-[inherit]",
    { "text-muted-foreground": tone === "muted" },
    className,
  ]}
  data-page-view-stats
  data-pathname={pathname}
  aria-live="polite"
>
  {
    showPageViews && (
      <>
        <span>Views</span>
        <span data-page-views>--</span>
      </>
    )
  }
  {showPageViews && showSiteViews && <span aria-hidden="true">·</span>}
  {
    showSiteViews && (
      <>
        <span>Site visits</span>
        <span data-site-views>--</span>
      </>
    )
  }
</div>

<script is:inline data-astro-rerun>
  (function () {
    const roots = Array.from(
      document.querySelectorAll("[data-page-view-stats]")
    ).filter(root => !root.dataset.viewStatsMounted);
    if (roots.length === 0) return;

    function formatCount(value) {
      const number = Number(value || 0);
      return new Intl.NumberFormat("zh-CN").format(number);
    }

    function render(root, data) {
      if (!data) return;
      const pathname = root.getAttribute("data-pathname") || location.pathname;
      const pageViews = root.querySelector("[data-page-views]");
      const siteViews = root.querySelector("[data-site-views]");
      if (pageViews && data.pathname === pathname) {
        pageViews.textContent = formatCount(data.pageViews);
      }
      if (siteViews) siteViews.textContent = formatCount(data.siteViews);
    }

    roots.forEach(root => {
      root.dataset.viewStatsMounted = "true";
      render(root, window.__blogViewStats);

      document.addEventListener("blog:view-stats", event => {
        render(root, event.detail);
      });

      const pathname = root.getAttribute("data-pathname") || location.pathname;
      fetch(`/api/views?pathname=${encodeURIComponent(pathname)}`, {
        headers: { accept: "application/json" },
      })
        .then(response => (response.ok ? response.json() : null))
        .then(data => render(root, data))
        .catch(() => {});
    });
  })();
</script>
